generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OccupancyStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum UserRole {
  ADMIN
  JURISTIC
  MAINTENANCE
  GUARD
  RESIDENT
}

enum ResidentType {
  OWNER
  TENANT
}

enum ResidentStatus {
  ACTIVE
  INACTIVE
}

enum AnnouncementStatus {
  ACTIVE
  EXPIRED
}

model Building {
  id          String   @id @default(uuid())
  name        String
  address     String
  totalFloors Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floors Floor[]
}

model Floor {
  id          String   @id @default(uuid())
  floorNumber Int
  buildingId  String
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units Unit[]

  @@unique([buildingId, floorNumber])
}

model Unit {
  id              String          @id @default(uuid())
  unitNumber      String
  floorId         String
  floor           Floor           @relation(fields: [floorId], references: [id], onDelete: Cascade)
  area            Float
  bedrooms        Int             @default(1)
  bathrooms       Int             @default(1)
  occupancyStatus OccupancyStatus @default(AVAILABLE)
  monthlyRent     Decimal         @db.Decimal(10, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  residents Resident[]
  visitors  Visitor[]

  @@unique([floorId, unitNumber])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(MAINTENANCE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  residents             Resident[]
  announcements         Announcement[]
  announcementReads     AnnouncementRead[]
  recordedVisitors      Visitor[] @relation("RecordedBy")
  checkedOutVisitors    Visitor[] @relation("CheckedOutBy")
}

model Visitor {
  id           String    @id @default(uuid())
  name         String
  phone        String?
  purpose      String?
  vehiclePlate String?
  groupSize    Int       @default(1)
  unitId       String
  unit         Unit      @relation(fields: [unitId], references: [id])
  residentId   String?
  resident     Resident? @relation(fields: [residentId], references: [id])
  checkInAt      DateTime  @default(now())
  checkOutAt     DateTime?
  recordedById   String
  recordedBy     User      @relation("RecordedBy", fields: [recordedById], references: [id])
  checkedOutById  String?
  checkedOutBy    User?     @relation("CheckedOutBy", fields: [checkedOutById], references: [id])
  isAutoExpired   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Resident {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  unitId       String
  unit         Unit           @relation(fields: [unitId], references: [id])
  residentType ResidentType
  status       ResidentStatus @default(ACTIVE)
  moveInDate   DateTime
  moveOutDate  DateTime?
  note         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  familyMembers     FamilyMember[]
  emergencyContacts EmergencyContact[]
  visitors          Visitor[]
}

model FamilyMember {
  id           String   @id @default(uuid())
  residentId   String
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  relationship String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmergencyContact {
  id           String   @id @default(uuid())
  residentId   String
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  relationship String
  phone        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Announcement {
  id          String             @id @default(uuid())
  title       String
  content     String
  isPinned    Boolean            @default(false)
  status      AnnouncementStatus @default(ACTIVE)
  expiredAt   DateTime?
  createdById String
  createdBy   User               @relation(fields: [createdById], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  reads AnnouncementRead[]
}

model AnnouncementRead {
  userId         String
  announcementId String
  readAt         DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@id([userId, announcementId])
}
