generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PROPERTY_MANAGER
  STAFF
  RESIDENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
